# Groq API (get free key at console.groq.com)
GROQ_API_KEY=

# JWT (any long random string — run: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=

# Gmail SMTP (NOT your Gmail password — use an App Password from Google Account settings)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Reddit API (create an app at reddit.com/prefs/apps — choose "script" type)
REDDIT_CLIENT_ID=
REDDIT_SECRET=
REDDIT_USER_AGENT=newsletter_curator/1.0
